# =============================================================================
# DaiBai — .gitignore
# =============================================================================
# Rule of thumb: commit SOURCE files; never commit BUILD OUTPUTS.
#
# SOURCE files we always want in git:
#   Dockerfile, .dockerignore, docker-compose.yml, docker-compose.*.yml
#   requirements.txt, pyproject.toml, .env.example, scripts/*, docs/*, etc.
#
# BUILD OUTPUTS we never want in git:
#   Python dist/build/, Docker image tarballs, coverage reports, logs, etc.
# =============================================================================

# =============================================================================
# PYTHON — compiled / built
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Built distributions and packaging artefacts
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Stray files from redirect typos (e.g. 2>=0.6.2 creates =0.6.2)
=*
# Stray files from accidental pip install typos
pip-log.txt
pip-*.txt

# Virtual environments
.venv/
venv/
ENV/
env/

# =============================================================================
# DOCKER — keep source files, exclude build outputs
# =============================================================================
# KEEP (committed to git — these are configuration/source):
#   Dockerfile
#   .dockerignore
#   docker-compose.yml
#   docker-compose.<env>.yml
#
# EXCLUDE (build outputs and machine-local overrides):

# Machine-specific compose overrides
docker-compose.override.yml

# Docker daemon state and credential helpers written to the project dir
.docker/

# Docker BuildKit / buildx local cache and state
.buildx/
**/.buildx/

# Image archives — produced by `docker save` or `docker export`
# e.g. `docker save myapp:latest > myapp.tar`
*.tar
*.tar.gz
*.image.tar

# Bind-mount volume data directories (if created locally)
docker-volumes/
.dockervolume/

# =============================================================================
# TESTING & COVERAGE REPORTS
# =============================================================================
.pytest_cache/
.coverage
.coverage.*
*.cover
htmlcov/

# Machine-readable coverage and test result files (generated by CI / pytest)
coverage.xml
junit*.xml
test-results/

# =============================================================================
# SECRETS & ENVIRONMENT
# =============================================================================
.env
.env.local
.env.*.local
# daibai.yaml holds real DB credentials — never commit it
daibai.yaml

# Service account keys, Firebase admin keys, TLS certs — never commit
config/secrets/
*firebase-adminsdk*.json
*service-account*.json
*serviceAccount*.json

# =============================================================================
# DATA & LOCAL DATABASES
# =============================================================================
# .db files in data/ are runtime state, not source.
# chinook_master.db and playground.db are generated at runtime.
*.db
*.sqlite3
*.sqlite
exports/

# =============================================================================
# LOGS
# =============================================================================
*.log
logs/
log/

# =============================================================================
# DOCS BUILD OUTPUT
# =============================================================================
# Keep docs/*.md source files. Exclude rendered/compiled output:
site/       # MkDocs: mkdocs build
_site/      # Jekyll
_build/     # Sphinx

# =============================================================================
# USER DATA & LOCAL APP STATE
# =============================================================================
.daibai/
chats/

# =============================================================================
# IDE & EDITOR
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~

# =============================================================================
# OS ARTEFACTS
# =============================================================================
.DS_Store
Thumbs.db

# =============================================================================
# STATIC ANALYSIS & TYPE CHECKING CACHES
# =============================================================================
.mypy_cache/
.ruff_cache/
.tox/
.hypothesis/

# =============================================================================
# WORKSPACE / PERSONAL PREFERENCES
# =============================================================================
# .code-workspace files contain machine-specific paths — keep out of git
*.code-workspace
