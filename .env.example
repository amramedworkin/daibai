# Daiby Environment Variables
# Copy this file to .env and fill in your secrets

# LLM API Keys (add the ones you use)
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key
OPENAI_ORG=your-openai-org-id
AZURE_OPENAI_KEY=your-azure-openai-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Azure Cache for Redis (from ./scripts/cli.sh redis-create)
# REDIS_URL=rediss://:access-key@daibai-redis.redis.cache.windows.net:6380

# Semantic cache: always used when REDIS_URL is set. Set to 1 to disable (testing/debug).
# DAIBAI_DISABLE_SEMANTIC_CACHE=0

# Precision for semantic cache matching (0.0–1.0). High values = stricter.
# CACHE_THRESHOLD=0.90
# SEMANTIC_SIMILARITY_THRESHOLD=0.90

# Max tables to send to LLM (semantic schema pruning). 1–20. Default 12 (complex JOINs).
# Use @metrics in CLI to see usage and suggested_limit for tuning.
# SCHEMA_VECTOR_LIMIT=12

# (Planned) How often (seconds) to re-scan DB schema. Not yet implemented.
# SCHEMA_REFRESH_INTERVAL=3600

# Database Credentials
DB_PROD_HOST=your-production-host.com
DB_PROD_USER=your_user
DB_PROD_PASSWORD=your_password

DB_STAGING_USER=staging_user
DB_STAGING_PASSWORD=staging_password

DB_DEV_PASSWORD=dev_password

# ==========================================
# 1. IDENTITY PLANE (User Authentication)
# ==========================================
# The Entra ID Tenant where users are stored (e.g., DaiBai Tenant)
AUTH_TENANT_ID="e12adb01-a6b3-47bb-86c0-d662dacb3675"
# The App Registration Client ID for the Web UI/API
AUTH_CLIENT_ID="your_app_registration_client_id"

# ==========================================
# 2. INFRASTRUCTURE PLANE (Backend Services)
# ==========================================
# The Tenant where Azure resources live (e.g., IT Protects Tenant)
AZURE_TENANT_ID="your_it_protects_tenant_id"
