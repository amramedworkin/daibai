# DaiBai .env.example
# Copy to .env and fill in real values for local development or CI.
# Run: ./scripts/cli.sh sp-create  to get AZURE_TENANT_ID, AZURE_CLIENT_ID (and AZURE_CLIENT_SECRET on first create)

# -------------------------
# Azure Service Principal (DefaultAzureCredential for Cosmos, Key Vault)
# -------------------------
AZURE_CLIENT_NAME=DaiBaiApp      # Service principal display name (required for sp-create lookup; cannot be retrieved from Azure)
AZURE_TENANT_NAME=               # Tenant/organization display name (from: ./scripts/cli.sh sp-create)
AZURE_TENANT_ID=                 # From: ./scripts/cli.sh sp-create
AZURE_CLIENT_ID=                  # From: ./scripts/cli.sh sp-create
AZURE_CLIENT_SECRET=              # From: ./scripts/cli.sh sp-create (or Azure Portal → App registrations → DaiBaiApp → Certificates & secrets)
AZURE_SUBSCRIPTION_ID=            # Optional; defaults to 'az account show' for cosmos-role-sp

# -------------------------
# Cosmos DB (optional)
# -------------------------
COSMOS_ENDPOINT=                 # https://<account>.documents.azure.com:443/
COSMOS_DATABASE=daibai-metadata  # default DB name
COSMOS_CONTAINER=conversations   # default container
COSMOS_ACCOUNT=                   # Cosmos account name (used by az cli scripts)
COSMOS_RESOURCE_GROUP=            # Cosmos resource group (e.g. daibai-rg); used by cosmos-role-sp, cosmos-allow-ip
COSMOS_DB=daibai-metadata         # Alternative/alias for COSMOS_DATABASE

# -------------------------
# Redis / Cache
# -------------------------
REDIS_URL=                       # e.g. redis://:password@host:6379/0
REDIS_RESOURCE_GROUP=            # Azure Redis resource group (e.g. daibai-rg)
REDIS_NAME=                      # Azure Redis cache name (e.g. daibai-redis)
AZURE_REDIS_CONNECTION_STRING=   # Azure Redis connection string (alternative)
AZURE_REDIS_HOST=                # Redis host when using Entra ID
AZURE_REDIS_PORT=6380

# -------------------------
# MySQL / Database (optional)
# -------------------------
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=
# Runtime DB (e.g. SuiteCRM on Azure MySQL)
DB_RUNTIME_HOST=
DB_RUNTIME_USER=
DB_RUNTIME_PASSWORD=
# Source / Legacy DB (optional)
DB_SOURCE_USER=
DB_SOURCE_PASSWORD=
# Legacy aliases supported by scripts (optional)
MYSQL_HOST=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# -------------------------
# Key Vault / Secrets
# -------------------------
KEY_VAULT_URL=                   # e.g. https://my-vault.vault.azure.net/
KEY_VAULT_NAME=                  # Key Vault name (e.g. daibai-kv)
KEY_VAULT_RESOURCE_GROUP=        # Key Vault resource group (e.g. daibai-rg)

# -------------------------
# LLM / API keys (examples)
# -------------------------
OPENAI_API_KEY=
GEMINI_API_KEY=
AZURE_OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
NVIDIA_API_KEY=
ALIBABA_API_KEY=
META_API_KEY=
HF_TOKEN=                        # Hugging Face token to authenticate model downloads (optional)

# -------------------------
# App / Agent tuning
# -------------------------
SCHEMA_VECTOR_LIMIT=12
SCHEMA_REFRESH_INTERVAL=86400
CACHE_THRESHOLD=0.90
SEMANTIC_SIMILARITY_THRESHOLD=0.90

# -------------------------
# Debug / Feature flags
# -------------------------
DAIBAI_DEBUG_MODELS=0
DAIBAI_DISABLE_SEMANTIC_CACHE=0

# Daiby Environment Variables
# Copy this file to .env and fill in your secrets

# LLM API Keys (add the ones you use)
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key
OPENAI_ORG=your-openai-org-id
AZURE_OPENAI_KEY=your-azure-openai-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Azure Cache for Redis (from ./scripts/cli.sh redis-create)
# REDIS_URL=rediss://:access-key@daibai-redis.redis.cache.windows.net:6380

# Semantic cache: always used when REDIS_URL is set. Set to 1 to disable (testing/debug).
# DAIBAI_DISABLE_SEMANTIC_CACHE=0

# Precision for semantic cache matching (0.0–1.0). High values = stricter.
# CACHE_THRESHOLD=0.90
# SEMANTIC_SIMILARITY_THRESHOLD=0.90

# Max tables to send to LLM (semantic schema pruning). 1–20. Default 12 (complex JOINs).
# Use @metrics in CLI to see usage and suggested_limit for tuning.
# SCHEMA_VECTOR_LIMIT=12

# (Planned) How often (seconds) to re-scan DB schema. Not yet implemented.
# SCHEMA_REFRESH_INTERVAL=3600

# Database Credentials
DB_PROD_HOST=your-production-host.com
DB_PROD_USER=your_user
DB_PROD_PASSWORD=your_password

DB_STAGING_USER=staging_user
DB_STAGING_PASSWORD=staging_password

DB_DEV_PASSWORD=dev_password

# ==========================================
# Firebase Authentication
# ==========================================
FIREBASE_SERVICE_ACCOUNT_JSON=   # Path to firebase-adminsdk.json (e.g. config/secrets/firebase-adminsdk.json)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

