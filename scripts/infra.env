# ============================================================================
# DaiBai Infrastructure Shared Configuration (infra.env)
# ----------------------------------------------------------------------------
# IMPORTANT: Change UNIQUE_SUFFIX to a globally unique string before deploying.
# Alphanumeric only, no spaces or special characters.
# ============================================================================

UNIQUE_SUFFIX="20110922"
AZURE_LOCATION="eastus"

# Core Unified Resource Group
AZURE_RG_NAME="rg-daibai-prod"

# Legacy Variable Mappings (Ensures backward compatibility)
REDIS_RESOURCE_GROUP=$AZURE_RG_NAME
KEY_VAULT_RESOURCE_GROUP=$AZURE_RG_NAME
COSMOS_RESOURCE_GROUP=$AZURE_RG_NAME

# Production Resource Names
LOG_WORKSPACE_NAME="log-daibai-prod"
COSMOS_ACCOUNT_NAME="cosmos-daibai-$UNIQUE_SUFFIX"
KV_NAME="kv-daibai-$UNIQUE_SUFFIX"
ACR_NAME="acrdaibai$UNIQUE_SUFFIX"
ACA_ENV_NAME="cae-daibai-prod"
REDIS_NAME="redis-daibai-$UNIQUE_SUFFIX"
